# === Eldad Brain App — Environment Variables ===

# Google Gemini API Key (for BrainChat)
VITE_GEMINI_API_KEY=your-gemini-api-key

# Gmail OAuth2 Client ID (for real email sync)
# Setup: https://console.cloud.google.com
# 1. Create a project (or use existing)
# 2. Enable "Gmail API" in APIs & Services
# 3. Create OAuth 2.0 credentials → Web Application
# 4. Add http://localhost:5173 to "Authorized JavaScript origins"
# 5. Copy the Client ID here:
VITE_GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
